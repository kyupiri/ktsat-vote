<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KTSAT AI 바이브코딩 해커톤 투표</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #05060f; --surface: rgba(20, 26, 54, 0.72); --surface-solid: #0c1230;
    --border: rgba(120, 140, 220, 0.22);
    --text-primary: #eef1fb; --text-secondary: #aab2d8; --text-muted: #6f78a8;
    --teal: #38bdf8; --teal-light: rgba(56, 189, 248, 0.14); --teal-dark: #7dd3fc; --teal-mid: #22d3ee;
    --coral: #fb7185; --coral-light: rgba(251, 113, 133, 0.14);
    --gold: #fcd34d; --silver: #cbd5e1; --bronze: #f0a868;
    --purple: #a78bfa; --purple-light: rgba(167, 139, 250, 0.16);
    --glow-teal: 0 0 22px rgba(56, 189, 248, 0.45);
    --glow-purple: 0 0 22px rgba(167, 139, 250, 0.4);
  }
  html, body { height: 100%; }
  body {
    font-family: -apple-system, 'Segoe UI', sans-serif;
    color: var(--text-primary); min-height: 100vh; position: relative;
    background:
      radial-gradient(ellipse 90% 60% at 15% 0%, rgba(88, 28, 135, 0.45), transparent 60%),
      radial-gradient(ellipse 80% 55% at 85% 10%, rgba(14, 116, 144, 0.4), transparent 55%),
      radial-gradient(ellipse 70% 60% at 50% 100%, rgba(30, 64, 175, 0.35), transparent 60%),
      linear-gradient(180deg, #05060f 0%, #080b1e 50%, #05060f 100%);
    background-attachment: fixed;
    overflow-x: hidden;
  }
  /* 별 필드 */
  body::before, body::after {
    content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
  }
  body::before {
    background-image:
      radial-gradient(1.6px 1.6px at 20% 30%, #fff, transparent),
      radial-gradient(1.4px 1.4px at 70% 60%, #cfe0ff, transparent),
      radial-gradient(1.2px 1.2px at 40% 80%, #fff, transparent),
      radial-gradient(1.8px 1.8px at 85% 25%, #fff, transparent),
      radial-gradient(1.2px 1.2px at 55% 15%, #bcd0ff, transparent),
      radial-gradient(1.4px 1.4px at 10% 70%, #fff, transparent),
      radial-gradient(1.2px 1.2px at 92% 78%, #e0e8ff, transparent),
      radial-gradient(1.6px 1.6px at 33% 50%, #fff, transparent);
    background-repeat: repeat; background-size: 320px 320px;
    animation: twinkle 5s ease-in-out infinite;
  }
  body::after {
    background-image:
      radial-gradient(1px 1px at 12% 22%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1px 1px at 62% 42%, rgba(180,200,255,0.6), transparent),
      radial-gradient(1px 1px at 48% 88%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 88% 62%, rgba(255,255,255,0.5), transparent);
    background-repeat: repeat; background-size: 200px 200px;
    animation: twinkle 7s ease-in-out infinite reverse;
  }
  @keyframes twinkle { 0%,100%{opacity:0.85} 50%{opacity:0.35} }
  .topbar, .container { position: relative; z-index: 1; }

  .topbar {
    background: rgba(8, 11, 30, 0.7); backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border); padding: 0 2rem; height: 56px;
    display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; z-index: 100;
  }
  .topbar-logo { font-size: 15px; font-weight: 700; letter-spacing: 0.5px; }
  .topbar-logo span { color: var(--teal); text-shadow: var(--glow-teal); }
  .topbar-status { font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 8px; }
  .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); box-shadow: var(--glow-teal); animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .container { max-width: 980px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
  .hero { margin-bottom: 2rem; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; color: var(--teal); margin-bottom: 8px; text-shadow: var(--glow-teal); }
  .hero h1 { font-size: 30px; font-weight: 700; letter-spacing: -0.6px; margin-bottom: 8px; background: linear-gradient(120deg, #fff 0%, #a5b4fc 50%, #38bdf8 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .hero p { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
  .selector-wrap { display: flex; align-items: center; gap: 12px; background: var(--surface); backdrop-filter: blur(12px); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .selector-wrap label { font-size: 14px; color: var(--text-secondary); white-space: nowrap; }
  .selector-wrap select { flex: 1; min-width: 160px; font-size: 14px; font-family: inherit; padding: 8px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-solid); color: var(--text-primary); cursor: pointer; outline: none; }
  .selector-wrap select:focus { border-color: var(--teal); box-shadow: var(--glow-teal); }
  .btn-reset { font-size: 13px; color: var(--text-muted); background: none; border: none; cursor: pointer; font-family: inherit; text-decoration: underline; text-underline-offset: 2px; padding: 0; display: none; }
  .btn-reset:hover { color: var(--coral); }
  .voter-type-badge { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
  .voter-type-badge.judge { background: var(--purple-light); color: var(--purple); border: 1px solid rgba(167,139,250,0.35); }
  .voter-type-badge.team { background: var(--teal-light); color: var(--teal-dark); border: 1px solid rgba(56,189,248,0.35); }
  .main-grid { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; align-items: start; }
  @media(max-width:720px){ .main-grid { grid-template-columns: 1fr; } }
  .card { background: var(--surface); backdrop-filter: blur(14px); border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; box-shadow: 0 8px 40px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.04); }
  .card-title { font-size: 12px; font-weight: 700; color: var(--text-muted); letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 1.25rem; }
  .vote-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(128px, 1fr)); gap: 10px; margin-bottom: 1.25rem; }
  .team-card { border: 1.5px solid var(--border); border-radius: 12px; padding: 14px 12px; background: rgba(12, 18, 48, 0.6); cursor: pointer; transition: all 0.18s; user-select: none; position: relative; }
  .team-card:hover:not(.self):not(.voted-state) { border-color: var(--teal-mid); background: var(--teal-light); transform: translateY(-2px); box-shadow: var(--glow-teal); }
  .team-card.selected { border: 2px solid var(--teal); background: var(--teal-light); box-shadow: var(--glow-teal); }
  .team-card.rank1 { border: 2px solid var(--gold); background: rgba(252,211,77,0.12); box-shadow: 0 0 20px rgba(252,211,77,0.35); }
  .team-card.rank2 { border: 2px solid var(--silver); background: rgba(203,213,225,0.1); box-shadow: 0 0 18px rgba(203,213,225,0.25); }
  .team-card.rank3 { border: 2px solid var(--bronze); background: rgba(240,168,104,0.12); box-shadow: 0 0 18px rgba(240,168,104,0.3); }
  .rank-badge { position: absolute; top: 9px; right: 9px; height: 20px; padding: 0 8px; border-radius: 10px; display: none; align-items: center; justify-content: center; font-size: 11px; font-weight: 800; color: #05060f; white-space: nowrap; }
  .team-card.rank1 .rank-badge { display: flex; background: var(--gold); }
  .team-card.rank2 .rank-badge { display: flex; background: var(--silver); }
  .team-card.rank3 .rank-badge { display: flex; background: var(--bronze); }
  .team-card.rank1 .tnum, .team-card.rank2 .tnum, .team-card.rank3 .tnum,
  .team-card.rank1 .tname, .team-card.rank2 .tname, .team-card.rank3 .tname { color: var(--text-primary); }
  .rank-hint { font-size: 11px; font-weight: 700; }
  .rank-hint .h1 { color: var(--gold); } .rank-hint .h2 { color: var(--silver); } .rank-hint .h3 { color: var(--bronze); }
  .team-card.self { opacity: 0.3; cursor: not-allowed; background: rgba(8,11,30,0.5); }
  .team-card.voted-state { cursor: default; }
  .team-card .tnum { font-size: 10px; font-weight: 700; letter-spacing: 1px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 4px; }
  .team-card.selected .tnum { color: var(--teal-dark); }
  .team-card .tname { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
  .team-card.selected .tname { color: var(--teal-dark); }
  .team-card .tvotes { font-size: 13px; color: var(--text-muted); }
  .team-card.selected .tvotes { color: var(--teal); font-weight: 500; }
  .check-icon { position: absolute; top: 10px; right: 10px; width: 20px; height: 20px; border-radius: 50%; background: var(--teal); box-shadow: var(--glow-teal); display: none; align-items: center; justify-content: center; }
  .team-card.selected .check-icon { display: flex; }
  .check-icon svg { width: 11px; height: 11px; stroke: #05060f; fill: none; stroke-width: 2.5; }
  .self-label { position: absolute; bottom: 8px; right: 8px; font-size: 9px; font-weight: 700; color: var(--text-muted); letter-spacing: 0.5px; }
  .notice { font-size: 13px; padding: 10px 14px; border-radius: 8px; margin-bottom: 1rem; display: none; }
  .notice.warn { background: var(--coral-light); color: var(--coral); border: 1px solid rgba(251,113,133,0.3); }
  .notice.ok { background: var(--teal-light); color: var(--teal-dark); border: 1px solid rgba(56,189,248,0.3); }
  .submit-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .sel-info { font-size: 13px; color: var(--text-secondary); }
  .sel-info strong { color: var(--text-primary); font-weight: 700; }
  .btn-vote { padding: 10px 24px; border-radius: 8px; border: none; background: linear-gradient(135deg, #38bdf8, #6366f1); color: #fff; font-family: inherit; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.18s; box-shadow: 0 4px 18px rgba(56,189,248,0.4); }
  .btn-vote:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 6px 26px rgba(99,102,241,0.6); }
  .btn-vote:disabled { opacity: 0.35; cursor: not-allowed; transform: none; box-shadow: none; }
  .result-panel { position: sticky; top: 72px; }
  .total-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--teal-light); color: var(--teal-dark); font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px; margin-bottom: 1rem; border: 1px solid rgba(56,189,248,0.3); }
  .result-list { display: flex; flex-direction: column; gap: 10px; }
  .result-row { display: flex; align-items: center; gap: 8px; }
  .r-rank { font-size: 16px; width: 26px; text-align: center; flex-shrink: 0; }
  .r-rank.num { font-size: 13px; font-weight: 500; color: var(--text-muted); }
  .r-name { font-size: 13px; font-weight: 500; width: 52px; flex-shrink: 0; }
  .r-bar-wrap { flex: 1; background: rgba(8,11,30,0.7); border-radius: 4px; height: 18px; overflow: hidden; }
  .r-bar { height: 100%; border-radius: 4px; background: var(--teal-mid); box-shadow: 0 0 10px rgba(34,211,238,0.5); transition: width 0.5s cubic-bezier(0.4,0,0.2,1); }
  .r-bar.r1 { background: var(--gold); box-shadow: 0 0 10px rgba(252,211,77,0.5); }
  .r-bar.r2 { background: var(--silver); }
  .r-bar.r3 { background: var(--bronze); }
  .r-cnt { font-size: 13px; font-weight: 600; color: var(--text-secondary); width: 24px; text-align: right; flex-shrink: 0; }
  .result-footer { margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 12px; color: var(--text-muted); }
  .voted-chip { display: inline-flex; align-items: center; gap: 5px; background: linear-gradient(135deg,#38bdf8,#6366f1); color: white; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; margin-left: 10px; vertical-align: middle; box-shadow: var(--glow-teal); }
  .loading-overlay { position: fixed; inset: 0; background: radial-gradient(ellipse at center, #0a0f28, #05060f); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; z-index: 999; }
  .loading-spinner { width: 36px; height: 36px; border: 3px solid var(--border); border-top-color: var(--teal); border-radius: 50%; animation: spin 0.8s linear infinite; box-shadow: var(--glow-teal); }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text { font-size: 14px; color: var(--text-secondary); letter-spacing: 0.5px; }
  .judge-notice { background: var(--purple-light); color: var(--purple); border: 1px solid rgba(167,139,250,0.3); border-radius: 10px; padding: 10px 14px; font-size: 13px; margin-bottom: 1rem; display: none; }

  /* 결과 잠금 패널 */
  .lock-panel { text-align: center; padding: 2rem 1rem; }
  .lock-icon { font-size: 32px; margin-bottom: 12px; filter: drop-shadow(0 0 12px rgba(167,139,250,0.6)); }
  .lock-title { font-size: 14px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
  .lock-desc { font-size: 13px; color: var(--text-muted); margin-bottom: 16px; }
  .pw-row { display: flex; gap: 8px; }
  .pw-input { flex: 1; font-size: 14px; font-family: inherit; padding: 9px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-solid); color: var(--text-primary); outline: none; letter-spacing: 2px; }
  .pw-input:focus { border-color: var(--purple); box-shadow: var(--glow-purple); }
  .pw-btn { padding: 9px 16px; border-radius: 8px; border: none; background: linear-gradient(135deg,#a78bfa,#7c3aed); color: white; font-family: inherit; font-size: 13px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 16px rgba(124,58,237,0.4); }
  .pw-btn:hover { transform: translateY(-1px); box-shadow: var(--glow-purple); }
  .pw-error { font-size: 12px; color: var(--coral); margin-top: 8px; display: none; }
  .lock-badge { display: inline-flex; align-items: center; gap: 5px; background: var(--purple-light); color: var(--purple); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; margin-bottom: 1rem; border: 1px solid rgba(167,139,250,0.35); }

  /* 평가위원 채점표 */
  .scoresheet-wrap { overflow-x: auto; margin-bottom: 1.25rem; }
  table.scoresheet { border-collapse: collapse; width: 100%; min-width: 560px; font-size: 13px; }
  table.scoresheet th, table.scoresheet td { border: 1px solid var(--border); padding: 6px 6px; text-align: center; }
  table.scoresheet thead th { background: rgba(99,102,241,0.28); color: #e0e7ff; font-weight: 700; font-size: 12px; line-height: 1.35; }
  table.scoresheet thead th.col-team { width: 70px; }
  table.scoresheet tbody td.team-name { font-weight: 700; color: var(--text-primary); background: rgba(12,18,48,0.6); text-align: left; padding-left: 10px; white-space: nowrap; }
  table.scoresheet tbody tr:nth-child(even) td.team-name { color: var(--teal-dark); }
  table.scoresheet input.score-input { width: 56px; font-size: 13px; font-family: inherit; text-align: center; padding: 6px 4px; border: 1px solid var(--border); border-radius: 6px; background: var(--surface-solid); color: var(--text-primary); outline: none; }
  table.scoresheet input.score-input:focus { border-color: var(--purple); background: var(--purple-light); box-shadow: var(--glow-purple); }
  table.scoresheet input.score-input.over { border-color: var(--coral); background: var(--coral-light); color: var(--coral); }
  table.scoresheet td.row-total { font-weight: 800; color: var(--purple); background: var(--purple-light); min-width: 56px; }
  table.scoresheet td.row-total.full { color: var(--teal-dark); }
  #scoresheetWrap { display: none; }

  /* 통합 종합 순위 표 */
  .combined-wrap { overflow-x: auto; }
  table.combined-table { border-collapse: collapse; width: 100%; font-size: 13px; }
  table.combined-table th, table.combined-table td { border-bottom: 1px solid var(--border); padding: 8px 6px; text-align: center; }
  table.combined-table thead th { font-size: 11px; font-weight: 700; color: var(--text-muted); letter-spacing: 0.4px; border-bottom: 1.5px solid var(--border); }
  table.combined-table thead th.col-team { text-align: left; }
  table.combined-table td.c-rank { width: 30px; font-weight: 700; }
  table.combined-table td.c-team { text-align: left; font-weight: 600; }
  table.combined-table td.c-judge { color: var(--purple); font-weight: 600; }
  table.combined-table td.c-team-vote { color: var(--teal); font-weight: 600; }
  table.combined-table td.c-total { font-weight: 800; color: var(--text-primary); }
  table.combined-table tbody tr.row1 td.c-total { color: var(--gold); }
  table.combined-table tbody tr.row2 td.c-total { color: var(--silver); }
  table.combined-table tbody tr.row3 td.c-total { color: var(--bronze); }
  table.combined-table tbody tr.row1 { background: rgba(252,211,77,0.1); }
  table.combined-table tbody tr.row2 { background: rgba(203,213,225,0.08); }
  table.combined-table tbody tr.row3 { background: rgba(240,168,104,0.1); }
</style>

</head>
<body>

<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-spinner"></div>
  <div class="loading-text">우주 정거장 접속 중...</div>
</div>

<div class="topbar">
  <div class="topbar-logo">AI <span>해커톤</span> 투표</div>
  <div class="topbar-status">
    <div class="live-dot"></div>
    <span id="statusText">연결 중</span>
  </div>
</div>

<div class="container">
  <div class="hero">
    <div class="hero-eyebrow">Voting · 실시간</div>
    <h1> 2026 KTSAT AI바이브코딩 해커톤 평가 <span id="votedChip" style="display:none" class="voted-chip">✓ 투표 완료</span></h1>
    <p> 혁신성, 사용자경험, 업무효율, 구현완성도, 실무적용 가능성 등을 종합적으로 고려하여 1~3등을 선정해 투표해 주세요.</p>
  </div>

  <div class="selector-wrap">
    <label for="myTeam">투표자 선택</label>
    <select id="myTeam">
      <option value="">-- 선택하세요 --</option>
      <optgroup label="팀"></optgroup>
      <optgroup label="평가위원"></optgroup>
    </select>
    <span id="voterBadge" class="voter-type-badge" style="display:none"></span>
    <button class="btn-reset" id="resetBtn">투표 초기화</button>
  </div>

  <div class="main-grid">
    <div>
      <div class="card">
        <div class="card-title" id="inputTitle">순위 투표 — 카드를 누르면 1→2→3등 순서로 지정됩니다</div>
        <div class="notice" id="notice"></div>
        <div class="judge-notice" id="judgeNotice">팀별 항목 점수를 입력하면 합계 기준 상위 3팀이 자동으로 1·2·3등이 됩니다 — 1등 6점 · 2등 4점 · 3등 2점이 집계에 반영됩니다. (항목별 만점 초과 불가 / 최소 3개 팀 채점)</div>

        <!-- 팀: 카드 순위 투표 -->
        <div class="vote-grid" id="voteGrid"></div>

        <!-- 평가위원: 채점표 -->
        <div id="scoresheetWrap" class="scoresheet-wrap"></div>

        <div class="submit-row">
          <div class="sel-info"><span class="rank-hint" id="rankHint"><span class="h1">🥇 -</span> · <span class="h2">🥈 -</span> · <span class="h3">🥉 -</span></span></div>
          <button class="btn-vote" id="submitBtn" disabled>투표하기 →</button>
        </div>
      </div>
    </div>

    <!-- 결과 패널 -->
    <div class="result-panel">
      <div class="card" id="resultCard">

        <!-- 잠금 상태 -->
        <div id="lockPanel" class="lock-panel">
          <div class="lock-icon">🔒</div>
          <div class="lock-title">결과는 평가위원만 볼 수 있습니다</div>
          <div class="lock-desc">비밀번호를 입력해 결과를 확인하세요</div>
          <div class="pw-row">
            <input class="pw-input" type="password" id="pwInput" placeholder="비밀번호" />
            <button class="pw-btn" id="pwBtn">확인</button>
          </div>
          <div class="pw-error" id="pwError">비밀번호가 올바르지 않습니다</div>
        </div>

        <!-- 결과 공개 상태 -->
        <div id="resultPanel" style="display:none">
          <div class="lock-badge">🔓 평가위원 전용</div>

          <div class="card-title" style="display:flex;align-items:center;gap:8px;">
            종합 순위 <span class="voter-type-badge judge">평가위원 6·4·2</span> <span class="voter-type-badge team">팀 투표</span>
          </div>
          <div class="total-badge">🔴 실시간 집계</div>
          <div class="combined-wrap">
            <table class="combined-table" id="combinedTable"></table>
          </div>

          <div class="result-footer">
            평가위원 합계 <span id="totalVotesJudge">0</span>점 &nbsp;·&nbsp; 팀 투표 <span id="totalVotesTeam">0</span>점 &nbsp;·&nbsp; <span id="votedCount">0</span>명 참여
            <br><button style="margin-top:8px; font-size:11px; color:var(--text-muted); background:none; border:none; cursor:pointer; text-decoration:underline; font-family:inherit;" id="lockAgainBtn">🔒 결과 잠금</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getDatabase, ref, onValue, runTransaction, set, get } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

  const RESULT_PW_HASH = '7e980b6326678addc99d00feb99c182deaa7ecea2c58ff40e1c6691cf801c105';

  async function sha256Hex(str) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
  }

  const firebaseConfig = {
    apiKey: "AIzaSyCYxpi_3lfFQ0Flg8h4PrYltefQGcUDiAE",
    authDomain: "ktsat-vote.firebaseapp.com",
    databaseURL: "https://ktsat-vote-default-rtdb.firebaseio.com",
    projectId: "ktsat-vote",
    storageBucket: "ktsat-vote.firebasestorage.app",
    messagingSenderId: "628500046974",
    appId: "1:628500046974:web:82a4d2682b38bd62d1e42f"
  };

  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);

  const TEAMS = Array.from({length: 10}, (_, i) => `팀 ${i+1}`);
  const JUDGES = Array.from({length: 5}, (_, i) => `평가위원${i+1}`);

  // 평가위원 채점 항목 (key, 라벨, 만점)
  const CRITERIA = [
    { key: 'impact',  label: '혁신성', max: 20 },
    { key: 'apply',   label: '사용자 경험', max: 20 },
    { key: 'scale',   label: '업무효율',     max: 20 },
    { key: 'impl',    label: '구현완성도', max: 20 },
    { key: 'present', label: '실무적용 가능성',   max: 20 },
  ];
  const MAX_TOTAL = CRITERIA.reduce((s, c) => s + c.max, 0); // 100

  let votesTeam = Object.fromEntries(TEAMS.map(t => [t, 0])); // 팀 투표 점수 풀
  let judgeAll = {};   // 전체 평가위원 점수 (결과 집계용): {judgeKey: {teamKey: {impact,...,_total}}}
  let myScores = {};   // 현재 평가위원이 입력 중인 점수: {team: {key: value}}
  let votedLog = {};
  let myTeam = '';
  let isJudge = false;
  let selected = [];
  let hasVoted = false;
  let resultUnlocked = false;

  const myTeamSel = document.getElementById('myTeam');
  const voteGrid = document.getElementById('voteGrid');
  const scoresheetWrap = document.getElementById('scoresheetWrap');
  const inputTitle = document.getElementById('inputTitle');
  const submitBtn = document.getElementById('submitBtn');
  const noticeEl = document.getElementById('notice');
  const judgeNotice = document.getElementById('judgeNotice');
  const resetBtn = document.getElementById('resetBtn');
  const votedChip = document.getElementById('votedChip');
  const statusText = document.getElementById('statusText');
  const voterBadge = document.getElementById('voterBadge');
  const pwInput = document.getElementById('pwInput');
  const pwBtn = document.getElementById('pwBtn');
  const pwError = document.getElementById('pwError');
  const lockPanel = document.getElementById('lockPanel');
  const resultPanel = document.getElementById('resultPanel');
  const lockAgainBtn = document.getElementById('lockAgainBtn');

  function showNotice(msg, type) {
    noticeEl.textContent = msg;
    noticeEl.className = 'notice ' + type;
    noticeEl.style.display = 'block';
  }
  function hideNotice() { noticeEl.style.display = 'none'; }

  const teamGroup = myTeamSel.querySelector('optgroup[label="팀"]');
  const judgeGroup = myTeamSel.querySelector('optgroup[label="평가위원"]');
  TEAMS.forEach(t => {
    const opt = document.createElement('option');
    opt.value = t; opt.textContent = t;
    teamGroup.appendChild(opt);
  });
  JUDGES.forEach(j => {
    const opt = document.createElement('option');
    opt.value = j; opt.textContent = j;
    judgeGroup.appendChild(opt);
  });

  pwBtn.addEventListener('click', checkPassword);
  pwInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') checkPassword(); });

  async function checkPassword() {
    const entered = await sha256Hex(pwInput.value);
    if (entered === RESULT_PW_HASH) {
      resultUnlocked = true;
      lockPanel.style.display = 'none';
      resultPanel.style.display = 'block';
      pwError.style.display = 'none';
      startResultSubscriptions(); // 잠금 해제 후에만 결과 데이터 수신
    } else {
      pwError.style.display = 'block';
      pwInput.value = '';
      pwInput.focus();
    }
  }

  let resultSubsStarted = false;
  function startResultSubscriptions() {
    if (resultSubsStarted) { renderResults(); return; }
    resultSubsStarted = true;
    onValue(ref(db, 'votesTeam'), (snap) => {
      if (snap.exists()) {
        const raw = snap.val();
        TEAMS.forEach(t => { votesTeam[t] = raw[t.replace(' ','_')] || 0; });
      }
      if (resultUnlocked) renderResults();
    });
    onValue(ref(db, 'judgeScores'), (snap) => {
      judgeAll = snap.exists() ? snap.val() : {};
      if (resultUnlocked) renderResults();
    });
    onValue(ref(db, 'votedTeams'), (snap) => {
      votedLog = snap.exists() ? snap.val() : {};
      if (resultUnlocked) renderResults();
    });
  }

  lockAgainBtn.addEventListener('click', () => {
    resultUnlocked = false;
    lockPanel.style.display = 'block';
    resultPanel.style.display = 'none';
    pwInput.value = '';
    pwError.style.display = 'none';
  });

  async function initDB() {
    try {
      const initObj = Object.fromEntries(TEAMS.map(t => [t.replace(' ','_'), 0]));
      const snapT = await get(ref(db, 'votesTeam'));
      if (!snapT.exists()) await set(ref(db, 'votesTeam'), {...initObj});
      statusText.textContent = '실시간 연결됨';
    } catch (e) {
      statusText.textContent = '연결 오류';
    }
    document.getElementById('loadingOverlay').style.display = 'none';
  }

  myTeamSel.addEventListener('change', async () => {
    const picked = myTeamSel.value;

    if (JUDGES.includes(picked)) {
      const entered = prompt('평가위원 인증을 위해 비밀번호를 입력하세요.');
      const ok = entered !== null && (await sha256Hex(entered)) === RESULT_PW_HASH;
      if (!ok) {
        if (entered !== null) showNotice('비밀번호가 올바르지 않아 평가위원 선택을 취소했어요.', 'warn');
        myTeamSel.value = '';
        myTeam = ''; isJudge = false; selected = []; myScores = {}; hasVoted = false;
        voterBadge.style.display = 'none';
        judgeNotice.style.display = 'none';
        votedChip.style.display = 'none';
        resetBtn.style.display = 'none';
        renderInput();
        updateSubmit();
        return;
      }
    }

    myTeam = myTeamSel.value;
    isJudge = JUDGES.includes(myTeam);
    selected = [];
    myScores = {};
    const myKey = myTeam.replace(/ /g, '_');

    let myPrev = null;
    if (myTeam) {
      try {
        if (isJudge) {
          const s = await get(ref(db, `judgeScores/${myKey}`));
          myPrev = s.exists() ? s.val() : null;
        } else {
          const s = await get(ref(db, `votedTeams/${myKey}`));
          myPrev = s.exists() ? s.val() : null;
        }
      } catch (e) { myPrev = null; }
    }
    hasVoted = !!(myTeam && myPrev);

    if (myTeam) {
      voterBadge.style.display = 'inline-flex';
      if (isJudge) {
        voterBadge.textContent = '평가위원';
        voterBadge.className = 'voter-type-badge judge';
        judgeNotice.style.display = 'block';
        inputTitle.textContent = '채점표 — 팀별 항목 점수를 입력하세요 (합계 100점)';
        // 기존 입력 점수 복원
        if (myPrev && typeof myPrev === 'object') {
          TEAMS.forEach(t => {
            const tk = t.replace(' ','_');
            if (myPrev[tk]) {
              myScores[t] = {};
              CRITERIA.forEach(c => { myScores[t][c.key] = Number(myPrev[tk][c.key]) || 0; });
            }
          });
        }
      } else {
        voterBadge.textContent = '팀';
        voterBadge.className = 'voter-type-badge team';
        judgeNotice.style.display = 'none';
        inputTitle.textContent = '순위 투표 — 카드를 누르면 1→2→3등 순서로 지정됩니다';
      }
    } else {
      voterBadge.style.display = 'none';
      judgeNotice.style.display = 'none';
      inputTitle.textContent = '순위 투표 — 카드를 누르면 1→2→3등 순서로 지정됩니다';
    }

    if (hasVoted) {
      votedChip.style.display = 'inline-flex';
      resetBtn.style.display = 'inline';
      if (!isJudge) selected = Array.isArray(myPrev) ? myPrev : [];
    } else {
      votedChip.style.display = 'none';
      resetBtn.style.display = 'none';
    }
    hideNotice();
    renderInput();
    updateSubmit();
  });

  resetBtn.addEventListener('click', resetVote);
  submitBtn.addEventListener('click', submitVote);

  function renderInput() {
    if (isJudge) {
      voteGrid.style.display = 'none';
      scoresheetWrap.style.display = 'block';
      renderScoresheet();
    } else {
      scoresheetWrap.style.display = 'none';
      voteGrid.style.display = 'grid';
      renderGrid();
    }
  }

  function teamTotal(team) {
    const sc = myScores[team] || {};
    return CRITERIA.reduce((s, c) => s + (Number(sc[c.key]) || 0), 0);
  }

  function renderScoresheet() {
    const head = `
      <tr>
        <th class="col-team">팀명</th>
        ${CRITERIA.map(c => `<th>${c.label}<br>(${c.max}점)</th>`).join('')}
        <th>합계<br>(${MAX_TOTAL}점)</th>
      </tr>`;
    const rows = TEAMS.map((team, i) => {
      const sc = myScores[team] || {};
      const cells = CRITERIA.map(c => {
        const v = (sc[c.key] === undefined || sc[c.key] === null) ? '' : sc[c.key];
        const dis = hasVoted ? 'disabled' : '';
        return `<td><input class="score-input" type="number" inputmode="decimal" step="0.5" min="0" max="${c.max}"
                  data-team="${team}" data-key="${c.key}" data-max="${c.max}" value="${v}" ${dis} placeholder="0"></td>`;
      }).join('');
      const tot = teamTotal(team);
      const full = tot === MAX_TOTAL ? ' full' : '';
      return `<tr>
        <td class="team-name">${team}</td>
        ${cells}
        <td class="row-total${full}" data-total-team="${team}">${tot}</td>
      </tr>`;
    }).join('');

    scoresheetWrap.innerHTML = `<table class="scoresheet"><thead>${head}</thead><tbody>${rows}</tbody></table>`;

    scoresheetWrap.querySelectorAll('input.score-input').forEach(inp => {
      inp.addEventListener('input', onScoreInput);
    });
  }

  function onScoreInput(e) {
    const inp = e.target;
    const team = inp.dataset.team;
    const key = inp.dataset.key;
    const max = Number(inp.dataset.max);
    let raw = inp.value.trim();

    if (raw === '') {
      if (myScores[team]) delete myScores[team][key];
      inp.classList.remove('over');
    } else {
      let val = Number(raw);
      if (isNaN(val) || val < 0) val = 0;
      const over = val > max;
      inp.classList.toggle('over', over);
      if (over) { val = max; inp.value = max; } // 만점 초과 방지: 자동 보정
      if (!myScores[team]) myScores[team] = {};
      myScores[team][key] = val;
    }

    // 합계 갱신
    const cell = scoresheetWrap.querySelector(`[data-total-team="${team}"]`);
    if (cell) {
      const tot = teamTotal(team);
      cell.textContent = tot;
      cell.classList.toggle('full', tot === MAX_TOTAL);
    }
    updateSubmit();
  }

  function renderGrid() {
    voteGrid.innerHTML = '';
    TEAMS.forEach((team, i) => {
      const isSelf = !isJudge && team === myTeam && myTeam !== '';
      const rankIdx = selected.indexOf(team); // 0,1,2 = 1,2,3등
      const rankCls = rankIdx === 0 ? ' rank1' : rankIdx === 1 ? ' rank2' : rankIdx === 2 ? ' rank3' : '';
      const card = document.createElement('div');
      card.className = 'team-card' + (isSelf?' self':'') + rankCls + (hasVoted?' voted-state':'');
      const medal = rankIdx === 0 ? '1등' : rankIdx === 1 ? '2등' : rankIdx === 2 ? '3등' : '';
      card.innerHTML = `
        <div class="tnum">TEAM ${String(i+1).padStart(2,'0')}</div>
        <div class="tname">${team}</div>
        <div class="rank-badge">${medal}</div>
        ${isSelf ? '<div class="self-label">OUR TEAM</div>' : ''}
      `;
      if (!isSelf && myTeam && !hasVoted) {
        card.addEventListener('click', () => toggleSelect(team));
      }
      voteGrid.appendChild(card);
    });
  }

  function toggleSelect(team) {
    if (selected.includes(team)) {
      selected = selected.filter(t => t !== team);
      hideNotice();
    } else {
      if (selected.length >= 3) { showNotice('1·2·3등 3팀까지만 선택할 수 있어요. 변경하려면 선택된 팀을 먼저 해제하세요.', 'warn'); return; }
      selected.push(team);
      hideNotice();
    }
    renderGrid();
    updateSubmit();
  }

  function updateSubmit() {
    const hint = document.getElementById('rankHint');
    if (isJudge) {
      const scored = TEAMS.filter(t => teamTotal(t) > 0);
      if (hint) {
        if (scored.length >= 3) {
          const ranked = TEAMS.slice().sort((a, b) => {
            const d = teamTotal(b) - teamTotal(a);
            if (d !== 0) return d;
            return TEAMS.indexOf(a) - TEAMS.indexOf(b);
          });
          const g = ranked[0], s = ranked[1], b = ranked[2];
          hint.innerHTML = `<span class="h1">🥇 ${g}</span> · <span class="h2">🥈 ${s}</span> · <span class="h3">🥉 ${b}</span>`;
        } else {
          hint.innerHTML = `<span style="color:var(--text-muted)">3개 팀 이상 채점하면 1·2·3등이 표시됩니다 (${scored.length}/3)</span>`;
        }
      }
      submitBtn.disabled = !(scored.length >= 3) || !myTeam || hasVoted;
    } else {
      const n = selected.length;
      if (hint) {
        const g = selected[0] || '-', s = selected[1] || '-', b = selected[2] || '-';
        hint.innerHTML = `<span class="h1">🥇 ${g}</span> · <span class="h2">🥈 ${s}</span> · <span class="h3">🥉 ${b}</span>`;
      }
      submitBtn.disabled = !(n === 3) || !myTeam || hasVoted;
    }
  }

  async function submitVote() {
    if (!myTeam || hasVoted) return;

    if (isJudge) {
      const scored = TEAMS.filter(t => teamTotal(t) > 0);
      if (scored.length < 3) {
        showNotice('1·2·3등을 가리려면 최소 3개 팀에 점수를 입력해야 해요.', 'warn');
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = '저장 중...';
      try {
        const myKey = myTeam.replace(/ /g, '_');

        // 채점표 합계로 상위 3팀 산정 (동점이면 팀 번호 빠른 순)
        const ranked = TEAMS.slice().sort((a, b) => {
          const d = teamTotal(b) - teamTotal(a);
          if (d !== 0) return d;
          return TEAMS.indexOf(a) - TEAMS.indexOf(b);
        });
        const top3 = ranked.slice(0, 3);          // [1등, 2등, 3등]
        const weights = [6, 4, 2];

        // 항목별 점수 + 합계 + 산정된 등수/가중치 저장
        const payload = {};
        TEAMS.forEach(t => {
          const tk = t.replace(' ', '_');
          const sc = myScores[t] || {};
          const rec = {};
          let tot = 0;
          CRITERIA.forEach(c => {
            const v = Number(sc[c.key]) || 0;
            rec[c.key] = v; tot += v;
          });
          rec._total = tot;
          const rk = top3.indexOf(t);              // 0,1,2 = 1·2·3등, 없으면 -1
          rec._weight = rk >= 0 ? weights[rk] : 0;  // 결과 집계에 쓰이는 가중치 점수
          payload[tk] = rec;
        });
        await set(ref(db, `judgeScores/${myKey}`), payload);
        hasVoted = true;
        votedChip.style.display = 'inline-flex';
        resetBtn.style.display = 'inline';
        showNotice(`${myTeam} 채점 완료! (🥇${top3[0]} 🥈${top3[1]} 🥉${top3[2]})`, 'ok');
        renderInput();
        updateSubmit();
      } catch(e) {
        showNotice('저장 중 오류가 발생했어요. 다시 시도해주세요.', 'warn');
        submitBtn.disabled = false;
      }
      submitBtn.textContent = '투표하기 →';
      return;
    }

    // 팀 순위 투표
    if (selected.length !== 3) return;
    submitBtn.disabled = true;
    submitBtn.textContent = '저장 중...';
    try {
      const points = [3, 2, 1];
      for (let i = 0; i < selected.length; i++) {
        const team = selected[i];
        await runTransaction(ref(db, `votesTeam/${team.replace(' ','_')}`), (cur) => (cur || 0) + points[i]);
      }
      await set(ref(db, `votedTeams/${myTeam.replace(/ /g,'_')}`), selected);
      hasVoted = true;
      votedChip.style.display = 'inline-flex';
      resetBtn.style.display = 'inline';
      showNotice(`${myTeam} 투표 완료! (🥇${selected[0]} 🥈${selected[1]} 🥉${selected[2]})`, 'ok');
      renderGrid();
      updateSubmit();
    } catch(e) {
      showNotice('저장 중 오류가 발생했어요. 다시 시도해주세요.', 'warn');
      submitBtn.disabled = false;
    }
    submitBtn.textContent = '투표하기 →';
  }

  async function resetVote() {
    if (!myTeam || !hasVoted) return;
    const entered = prompt(`${myTeam}의 투표를 초기화하려면 비밀번호를 입력하세요.`);
    if (entered === null) return; // 취소
    const enteredHash = await sha256Hex(entered);
    if (enteredHash !== RESULT_PW_HASH) {
      showNotice('비밀번호가 올바르지 않아 초기화를 취소했어요.', 'warn');
      return;
    }
    try {
      const myKey = myTeam.replace(/ /g, '_');
      if (isJudge) {
        await set(ref(db, `judgeScores/${myKey}`), null);
        myScores = {};
      } else {
        const s = await get(ref(db, `votedTeams/${myKey}`));
        const prev = s.exists() ? s.val() : [];
        const prevArr = Array.isArray(prev) ? prev : [];
        const points = [3, 2, 1];
        for (let i = 0; i < prevArr.length; i++) {
          const team = prevArr[i];
          const pt = points[i] || 0;
          await runTransaction(ref(db, `votesTeam/${team.replace(' ','_')}`), (cur) => Math.max((cur||0)-pt, 0));
        }
        await set(ref(db, `votedTeams/${myKey}`), null);
      }
      hasVoted = false;
      selected = [];
      votedChip.style.display = 'none';
      resetBtn.style.display = 'none';
      hideNotice();
      renderInput();
      updateSubmit();
    } catch(e) {
      showNotice('초기화 중 오류가 발생했어요.', 'warn');
    }
  }

  function renderResults() {
    // 평가위원 가중치(6/4/2) 합산 풀 계산
    const judgePool = Object.fromEntries(TEAMS.map(t => [t, 0]));
    const WEIGHTS = [6, 4, 2]; // 1·2·3등 가중치
    let judgeCount = 0;
    Object.values(judgeAll || {}).forEach(perJudge => {
      if (!perJudge || typeof perJudge !== 'object') return;
      judgeCount++;
      // 이 평가위원의 팀별 점수합계 산정
      const totals = TEAMS.map(t => {
        const rec = perJudge[t.replace(' ','_')];
        let tot = 0;
        if (rec && typeof rec === 'object') {
          tot = Number(rec._total);
          if (isNaN(tot)) { // 구버전 데이터 대비: 항목 점수 직접 합산
            tot = CRITERIA.reduce((s, c) => s + (Number(rec[c.key]) || 0), 0);
          }
        }
        return { team: t, tot };
      });
      // 점수합계 내림차순(동점이면 팀 번호 빠른 순)으로 정렬해 상위 3팀에만 6·4·2 부여
      totals.sort((a, b) => {
        const d = b.tot - a.tot;
        if (d !== 0) return d;
        return TEAMS.indexOf(a.team) - TEAMS.indexOf(b.team);
      });
      totals.forEach((row, i) => {
        if (i < 3 && row.tot > 0) judgePool[row.team] += WEIGHTS[i];
      });
    });

    // 통합 표 렌더링: 팀별 평가위원점수 + 팀투표점수 + 합계, 합계 기준 정렬
    const rows = TEAMS.map(t => ({
      team: t,
      judge: judgePool[t] || 0,
      teamVote: votesTeam[t] || 0,
      total: (judgePool[t] || 0) + (votesTeam[t] || 0),
    }));
    rows.sort((a, b) => {
      const d = b.total - a.total;
      if (d !== 0) return d;
      const dj = b.judge - a.judge; // 동점이면 평가위원 점수 우선
      if (dj !== 0) return dj;
      return TEAMS.indexOf(a.team) - TEAMS.indexOf(b.team);
    });

    const totalJudge = rows.reduce((s, r) => s + r.judge, 0);
    const totalTeamVote = rows.reduce((s, r) => s + r.teamVote, 0);

    const head = `<thead><tr>
        <th>순위</th>
        <th class="col-team">팀</th>
        <th>평가위원<br>(6·4·2)</th>
        <th>팀 투표</th>
        <th>합계</th>
      </tr></thead>`;
    const body = '<tbody>' + rows.map((r, i) => {
      const medal = r.total === 0 ? (i+1) : (i===0?'🥇':i===1?'🥈':i===2?'🥉':(i+1));
      const rowCls = r.total > 0 ? (i===0?'row1':i===1?'row2':i===2?'row3':'') : '';
      return `<tr class="${rowCls}">
        <td class="c-rank">${medal}</td>
        <td class="c-team">${r.team}</td>
        <td class="c-judge">${r.judge}</td>
        <td class="c-team-vote">${r.teamVote}</td>
        <td class="c-total">${r.total}점</td>
      </tr>`;
    }).join('') + '</tbody>';

    document.getElementById('combinedTable').innerHTML = head + body;
    document.getElementById('totalVotesJudge').textContent = totalJudge;
    document.getElementById('totalVotesTeam').textContent = totalTeamVote;
    document.getElementById('votedCount').textContent =
      judgeCount + Object.keys(votedLog).length;
  }

  initDB();
  renderInput();
</script>
</body>
</html>
